---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<span class="logo-box">&lt;/&gt;</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://linkedin.com/in/vgvenkat" target="_blank" class="social-btn" aria-label="LinkedIn">
				<svg viewBox="0 0 16 16" width="20" height="20">
					<path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
				</svg>
			</a>
			<a href="https://github.com/vgvenkat" target="_blank" class="social-btn" aria-label="GitHub">
				<svg viewBox="0 0 16 16" width="20" height="20">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		background: var(--primary);
		border-bottom: var(--border-thick);
	}

	nav {
		max-width: 1080px;
		margin: 0 auto;
		padding: 1em 1.5em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5em;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.6em;
		text-decoration: none;
		font-weight: 700;
	}

	.logo:hover {
		background: transparent;
	}

	.logo-box {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		background: #fff;
		border: var(--border);
		box-shadow: var(--shadow-sm);
		font-family: monospace;
		font-size: 1em;
		font-weight: 700;
		transition: all 0.12s ease;
	}

	.logo:hover .logo-box {
		transform: translate(-2px, -2px);
		box-shadow: var(--shadow);
	}

	.logo-text {
		font-size: 1.1em;
		text-transform: uppercase;
		letter-spacing: -0.02em;
		padding: 0.28em 0.5em;
		background: #fff;
		border: 3px solid #000;
		box-shadow: 4px 4px 0 #000;
	}

	.nav-links {
		display: flex;
		gap: 0.3em;
	}

	.social-links {
		display: flex;
		gap: 0.5em;
	}

	.social-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		background: #fff;
		border: var(--border);
		box-shadow: var(--shadow-sm);
		color: var(--text);
		text-decoration: none;
		transition: all 0.12s ease;
	}

	.social-btn:hover {
		background: var(--tertiary);
		transform: translate(-2px, -2px);
		box-shadow: var(--shadow);
	}

	@media (max-width: 720px) {
		nav {
			padding: 0.8em 1em;
			flex-wrap: wrap;
		}
		.logo-text {
			display: none;
		}
		.nav-links {
			order: 3;
			width: 100%;
			justify-content: center;
			padding-top: 0.8em;
			border-top: 4px solid #000;
			margin-top: 0.8em;
		}
	}
</style>
