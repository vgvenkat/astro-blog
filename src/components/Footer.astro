---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-box">
			<span class="logo-box">&lt;/&gt;</span>
			<div class="footer-info">
				<p class="footer-name">Venkat Ganesan</p>
				<p class="footer-tagline">Building the web, one component at a time.</p>
			</div>
		</div>
		<div class="footer-links">
			<a href="https://linkedin.com/in/vgvenkat" target="_blank" class="footer-btn">LinkedIn</a>
			<a href="https://github.com/vgvenkat" target="_blank" class="footer-btn">GitHub</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		margin-top: 3em;
		background: var(--tertiary);
		border-top: var(--border-thick);
		padding: 2.5em 1.5em;
	}

	.footer-content {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
		background: #fff;
		border: var(--border-thick);
		box-shadow: var(--shadow);
		padding: 1.5em;
	}

	.footer-box {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1em;
		margin-bottom: 1.5em;
	}

	.logo-box {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		background: var(--primary);
		border: var(--border);
		box-shadow: var(--shadow-sm);
		font-family: monospace;
		font-size: 1.1em;
		font-weight: 700;
	}

	.footer-info {
		text-align: left;
	}

	.footer-name {
		font-size: 1.2em;
		font-weight: 700;
		margin: 0;
		text-transform: uppercase;
	}

	.footer-tagline {
		font-size: 0.9em;
		color: #222;
		margin: 0;
	}

	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.8em;
		margin-bottom: 1.5em;
	}

	.footer-btn {
		display: inline-block;
		padding: 0.6em 1.2em;
		background: var(--secondary);
		border: var(--border);
		box-shadow: var(--shadow-sm);
		color: var(--text);
		text-decoration: none;
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.85em;
		transition: all 0.12s ease;
	}

	.footer-btn:hover {
		background: var(--primary);
		transform: translate(-2px, -2px);
		box-shadow: var(--shadow);
	}

	.copyright {
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0;
	}
</style>
