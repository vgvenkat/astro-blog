---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">Open to Work</div>
				<h1>Venkat Ganesan</h1>
				<p class="hero-subtitle">Senior Software Engineer in the Bay Area</p>
				<p class="hero-description">
					10+ years building scalable web applications with React, TypeScript, and Node.js.
					Passionate about accessibility, clean code, and mentoring engineers.
				</p>
				<div class="tech-stack">
					<span class="tech-tag">React</span>
					<span class="tech-tag secondary">Redux</span>
					<span class="tech-tag tertiary">TypeScript</span>
					<span class="tech-tag">Node.js</span>
					<span class="tech-tag accent">GraphQL</span>
				</div>
				<div class="cta-buttons">
					<a href="/blog" class="btn btn-primary">Read the Blog</a>
					<a href="/about" class="btn btn-secondary">About Me</a>
					<a href="https://linkedin.com/in/vgvenkat" target="_blank" class="btn btn-outline">LinkedIn</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		min-height: calc(100vh - 250px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2em 1em;
	}

	.hero {
		text-align: center;
		max-width: 740px;
		background: var(--bg-card);
		border: var(--border-thick);
		box-shadow: var(--shadow);
		padding: 2.2em 1.6em;
		position: relative;
	}

	.hero-badge {
		display: inline-block;
		padding: 0.5em 1.2em;
		background: var(--secondary);
		border: var(--border);
		box-shadow: var(--shadow-sm);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.85em;
		margin-bottom: 1.5em;
	}

	.hero h1 {
		font-size: clamp(2.6rem, 11vw, 4.8rem);
		margin-bottom: 0.15em;
		line-height: 1;
	}

	.hero-subtitle {
		font-size: 1.4em;
		font-weight: 700;
		margin-bottom: 1em;
		text-transform: uppercase;
		display: inline-block;
		padding: 0.25em 0.5em;
		background: var(--tertiary);
		border: 3px solid #000;
	}

	.hero-description {
		font-size: 1.1em;
		max-width: 500px;
		margin: 0 auto 1.5em;
		line-height: 1.6;
		font-weight: 600;
	}

	.tech-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		justify-content: center;
		margin-bottom: 2.2em;
	}

	.tech-tag {
		padding: 0.35em 0.75em;
		background: var(--primary);
		border: var(--border);
		box-shadow: var(--shadow-sm);
		font-family: monospace;
		font-weight: 700;
		font-size: 0.9em;
		text-transform: uppercase;
	}

	.tech-tag.secondary {
		background: var(--secondary);
	}

	.tech-tag.tertiary {
		background: var(--tertiary);
	}

	.tech-tag.accent {
		background: var(--accent);
		color: #000;
	}

	.cta-buttons {
		display: flex;
		gap: 0.8em;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		padding: 0.8em 1.5em;
		border: var(--border);
		box-shadow: var(--shadow-sm);
		font-weight: 700;
		font-size: 1em;
		text-decoration: none;
		text-transform: uppercase;
		transition: all 0.12s ease;
		cursor: pointer;
	}

	.btn:hover {
		transform: translate(-2px, -2px);
		box-shadow: var(--shadow);
	}

	.btn-primary {
		background: var(--primary);
		color: #000;
	}

	.btn-secondary {
		background: var(--secondary);
		color: #000;
	}

	.btn-outline {
		background: var(--tertiary);
		color: #000;
	}

	.btn-outline:hover {
		background: var(--accent);
		color: #000;
	}

	@media (max-width: 720px) {
		.hero {
			padding: 1.5em 1em;
		}
		.hero h1 {
			font-size: 2.3em;
		}
		.hero-subtitle {
			font-size: 1em;
		}
		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
		.btn {
			width: 100%;
			max-width: 250px;
			text-align: center;
		}
	}
</style>
